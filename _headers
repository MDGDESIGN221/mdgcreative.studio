# ── MDG Creative Studio — En-têtes HTTP (Cloudflare Pages) ──
# Placé à la racine du déploiement. Cloudflare Pages lit ce fichier automatiquement.

/*
  # — Sécurité —
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  X-DNS-Prefetch-Control: on

  # — CSP en mode observation (ne bloque RIEN, collecte seulement) —
  # Quand les rapports seront propres, renommer l'en-tête en "Content-Security-Policy" pour l'appliquer.
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://res.cloudinary.com; connect-src 'self' https://api.web3forms.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com; media-src 'self' https://res.cloudinary.com; base-uri 'self'; form-action 'self' https://api.web3forms.com; object-src 'none'; frame-ancestors 'self'

# — Cache long pour les assets immuables —
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
/*.js
  Cache-Control: public, max-age=31536000, immutable

# — Le HTML doit toujours être revalidé (contenu qui évolue) —
/*.html
  Cache-Control: public, max-age=0, must-revalidate
